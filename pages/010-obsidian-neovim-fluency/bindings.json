      "OBSIDIAN_VAULT",
      "SOLO_VAULT",
      "~/obsidian/SSD",
      "~/Obsidian/SoloDeveloper"
    ],
    "primary_mac": "/Users/saboor/Obsidian/SoloDeveloper",
    "workspaces": [
      { "name": "SSD", "path_from_config": "vaults.primary (resolved)" },
      { "name": "llm-wiki", "candidates": ["~/obsidian/llm-wiki", "~/Obsidian/LLM-Wiki"] }
